<%- include('../layout') %>

<section class="page-content">
    <div class="container">
        <h1>Dokumen Publik</h1>

        <div class="dokumen-list">
            <% if (dokumen && dokumen.length > 0) { %>
                <% dokumen.forEach(item => { %>
                    <div class="dokumen-item">
                        <div class="dokumen-icon">
                            <i class="fas fa-file-pdf"></i>
                        </div>
                        <div class="dokumen-info">
                            <h3><%= item.judul %></h3>
                            <p><%= item.deskripsi %></p>
                            <% if (item.kategori) { %>
                                <span class="badge"><%= item.kategori %></span>
                            <% } %>
                            <p class="dokumen-date">
                                <i class="fas fa-calendar"></i> <%= new Date(item.created_at).toLocaleDateString('id-ID') %>
                            </p>
                        </div>
                        <a href="/uploads/<%= item.file_path %>" class="btn btn-primary" download>
                            <i class="fas fa-download"></i> Unduh
                        </a>
                    </div>
                <% }); %>
            <% } else { %>
                <p class="no-data">Tidak ada dokumen publik</p>
            <% } %>
        </div>
    </div>
</section>
