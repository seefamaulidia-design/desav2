<%- include('../layout') %>

<section class="page-content">
    <div class="container">
        <h1>Data Dusun/RW/RT</h1>

        <div class="table-container">
            <table class="data-table">
                <thead>
                    <tr>
                        <th>Nama Dusun</th>
                        <th>Jumlah RW</th>
                        <th>Jumlah RT</th>
                        <th>Jumlah Penduduk</th>
                        <th>Kepala Dusun</th>
                    </tr>
                </thead>
                <tbody>
                    <% if (wilayah && wilayah.length > 0) { %>
                        <% wilayah.forEach(w => { %>
                            <tr>
                                <td><%= w.nama_dusun %></td>
                                <td><%= w.jumlah_rw || '-' %></td>
                                <td><%= w.jumlah_rt || '-' %></td>
                                <td><%= w.jumlah_penduduk %></td>
                                <td><%= w.kepala_dusun || '-' %></td>
                            </tr>
                        <% }); %>
                    <% } else { %>
                        <tr>
                            <td colspan="5" class="text-center">Tidak ada data wilayah</td>
                        </tr>
                    <% } %>
                </tbody>
            </table>
        </div>
    </div>
</section>
