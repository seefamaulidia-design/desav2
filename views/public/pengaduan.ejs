
<section class="page-content">
    <div class="container">
        <h1>Kontak dan Pengaduan</h1>

        <div class="contact-section">
            <div class="contact-info">
                <h2>Hubungi Kami</h2>
                <div class="info-box">
                    <h3>Kantor Desa Way Ilahan</h3>
                    <p><i class="fas fa-map-pin"></i> Desa Way Ilahan, Kecamatan Pulau Panggung, Kabupaten Tanggamus, Provinsi Lampung</p>
                    <p><i class="fas fa-phone"></i> Telepon: (0726) XXXXXXX</p>
                    <p><i class="fas fa-envelope"></i> Email: info@desawayilahan.id</p>
                </div>
            </div>

            <div class="contact-form">
                <h2>Form Pengaduan/Saran/Masukan</h2>
                <% if (successMessage) { %>
                    <div class="alert alert-success"><%= successMessage %></div>
                <% } %>
                <% if (errorMessage) { %>
                    <div class="alert alert-error"><%= errorMessage %></div>
                <% } %>
                <form id="pengaduanForm" method="POST" action="/pengaduan">
                    <div class="form-group">
                        <label for="nama">Nama Lengkap *</label>
                        <input type="text" id="nama" name="nama" required value="<%= formData.nama %>">
                    </div>

                    <div class="form-group">
                        <label for="email">Email *</label>
                        <input type="email" id="email" name="email" required value="<%= formData.email %>">
                    </div>

                    <div class="form-group">
                        <label for="telepon">Nomor Telepon</label>
                        <input type="tel" id="telepon" name="telepon" value="<%= formData.telepon %>">
                    </div>

                    <div class="form-group">
                        <label for="judul">Judul Pengaduan/Saran *</label>
                        <input type="text" id="judul" name="judul" required value="<%= formData.judul %>">
                    </div>

                    <div class="form-group">
                        <label for="isi">Isi Pengaduan/Saran *</label>
                        <textarea id="isi" name="isi" rows="6" required><%= formData.isi %></textarea>
                    </div>

                    <button type="submit" class="btn btn-primary">
                        <i class="fas fa-paper-plane"></i> Kirim Pengaduan
                    </button>
                </form>
            </div>
        </div>
    </div>
</section>
